---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/home/Hero.astro';
import TheConflict from '../components/home/TheConflict.astro';
import Partners from '../components/home/Partners.astro';
// Nosotros
import MissionVision from '../components/nosotros/MissionVision.astro';
import Values from '../components/nosotros/Values.astro';
import Team from '../components/nosotros/Team.astro';
import TeamMovil from '../components/nosotros/TeamMovil.astro';
// Soluciones
import SolutionsCarousel from '../components/soluciones/SolutionsCarousel.astro';
// Beneficios
import BenefitsGrid from '../components/beneficios/BenefitsGrid.astro';
import Stats from '../components/beneficios/Stats.astro';
---


<Layout
    title="Luatec Solutions | Infraestructura TI y Ciberseguridad"
    description="Luatec Solutions ofrece servicios integrales de conectividad, ciberseguridad y consultoría tecnológica para potenciar tu empresa. Expertos en TI."
>
    <Header />
    <main class="w-full relative">
        <Hero />

        <div class="hidden md:contents">
            <Stats />
            <Team />
        </div>

        <div class="contents md:hidden">
            <TeamMovil />
        </div>

        <Partners />

        <SolutionsCarousel />



        <Footer />
    </main>
</Layout>
