---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout title="Contacto - Luatec Solutions">
    <Header />
    <main class="pt-44 pb-12 md:pb-16 min-h-screen flex flex-col items-center">
        <ContactForm />
    </main>
    <Footer showCTA={false} />
</Layout>

<style is:global>
    body {
        position: relative !important;
    }

    body::before {
        background-color: #ffffff !important;
        background-image: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%) !important;
        mask-image: none !important;
        -webkit-mask-image: none !important;
        height: 100% !important;
    }

    body::after {
        background: transparent !important;
        height: 100% !important;
    }

    /* Header con gradiente azul fijo en la página del formulario */
    #main-header {
        background: linear-gradient(to bottom right, #053D8A, #031b40) !important;
    }

    #main-header #header-bg {
        background: transparent !important;
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
        border: none !important;
        box-shadow: none !important;
    }

    /* Logo visible en blanco sobre fondo azul */
    #main-header .logo img,
    #main-header div a img {
        filter: none !important;
    }

    /* Botón de mail visible sobre fondo azul */
    #main-header a[aria-label="Mensaje"] {
        border-color: rgba(255, 255, 255, 0.2) !important;
        background-color: rgba(255, 255, 255, 0.1) !important;
        color: white !important;
    }

    #main-header a[aria-label="Mensaje"]:hover {
        background-color: rgba(255, 255, 255, 0.2) !important;
    }
</style>
