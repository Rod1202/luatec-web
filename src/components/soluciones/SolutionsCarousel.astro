---
import { Image } from 'astro:assets';
import cloudImg from '../../assets/services_img/servicios_cloud.avif';
import cyberImg from '../../assets/services_img/ciberseguridad.avif';
import supportImg from '../../assets/services_img/soporte_mantenimiento.avif';
import consultingImg from '../../assets/services_img/consultoria_infraestructura.avif';
import hardwareImg from '../../assets/services_img/venta_hadware.avif';
import rentalImg from '../../assets/services_img/alquiler_computo.avif';

const solutions = [
  {
    title: 'Cloud e Infraestructura',
    description: 'Diseño y escalamiento de entornos cloud seguros y resilientes para operaciones críticas.',
    image: cloudImg,
    icon: 'dns',
    cta: 'Solicitar información',
  },
  {
    title: 'Venta de Hardware y Equipamiento',
    description: 'Suministro de equipos de alta gama y componentes de última generación para servidores y estaciones.',
    image: hardwareImg,
    icon: 'memory',
    cta: 'Solicitar información',
  },
  {
    title: 'Soporte Técnico y Mantenimiento',
    description: 'Resolución inmediata de incidencias y mantenimiento preventivo para su tranquilidad operativa.',
    image: supportImg,
    icon: 'build',
    cta: 'Solicitar información',
  },
  {
    title: 'Consultoría de TI e Infraestructura',
    description: 'Asesoramiento estratégico para alinear su tecnología con los objetivos comerciales de su empresa.',
    image: consultingImg,
    icon: 'groups',
    cta: 'Solicitar información',
  },
  {
    title: 'Ciberseguridad',
    description: 'Protección integral contra amenazas emergentes y auditorías de seguridad proactivas.',
    image: cyberImg,
    icon: 'security',
    cta: 'Solicitar información',
  },
  {
    title: 'Alquiler de equipos de cómputo',
    description: 'Soluciones flexibles de leasing tecnológico para proyectos temporales o escalado rápido.',
    image: rentalImg,
    icon: 'laptop_mac',
    cta: 'Solicitar información',
  },
];
---

<section class="section-standard" id="soluciones">
  <div class="container-main">

    <!-- Header -->
    <div class="text-center mb-14 md:mb-16">
      <span class="eyebrow">Excelencia Técnica</span>
      <h2 class="section-heading">Nuestras Soluciones</h2>
      <div class="heading-line"></div>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {solutions.map((solution) => (
        <div class="solution-card">

          <!-- Imagen de fondo absoluta -->
          <Image
            src={solution.image}
            alt={solution.title}
            class="card-img"
            loading="lazy"
          />

          <!-- Gradiente encima de la imagen -->
          <div class="card-overlay"></div>

          <!-- Contenido encima de todo -->
          <div class="card-content">
            <span class="material-symbols-outlined card-icon">
              {solution.icon}
            </span>
            <h3 class="card-title">{solution.title}</h3>
            <p class="card-description">{solution.description}</p>
            <a href="/formulario" class="card-link">
              {solution.cta}
              <span class="material-symbols-outlined card-link-icon">arrow_right_alt</span>
            </a>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* ── Header ── */
  .eyebrow {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: #1279C8;
    margin-bottom: 0.75rem;
  }

  .section-heading {
    font-size: clamp(1.875rem, 4vw, 3rem);
    font-weight: 800;
    color: #053D8A;
    letter-spacing: 0.02em;
    margin-bottom: 1rem;
  }

  .heading-line {
    width: 3rem;
    height: 4px;
    background: #1279C8;
    margin: 0 auto;
    border-radius: 9999px;
  }

  /* ── Card contenedor ── */
  .solution-card {
    position: relative;        /* contexto para hijos absolutos */
    height: 420px;
    border-radius: 1.25rem;
    overflow: hidden;
    background-color: #053D8A;
    cursor: pointer;
    box-shadow:
      0 4px 20px rgba(5, 61, 138, 0.2),
      inset 0 1px 1px rgba(255, 255, 255, 0.05);
    transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1),
                box-shadow  0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .solution-card:hover {
    transform: translateY(-6px);
    box-shadow:
      0 15px 40px rgba(5, 61, 138, 0.35),
      inset 0 1px 1px rgba(255, 255, 255, 0.08);
  }

  /* ── Imagen: cubre toda la card ── */
  .card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
    z-index: 0;
  }

  .solution-card:hover .card-img {
    transform: scale(1.05);
  }

  /* ── Overlay gradiente: de transparente arriba a azul abajo ── */
  .card-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(5, 61, 138, 0.05) 0%,
      rgba(5, 61, 138, 0.55) 45%,
      rgba(5, 61, 138, 0.97) 100%
    );
    transition: background 0.5s ease;
  }

  .solution-card:hover .card-overlay {
    background: linear-gradient(
      to bottom,
      rgba(5, 61, 138, 0.0)  0%,
      rgba(5, 61, 138, 0.5)  45%,
      rgba(5, 61, 138, 1.0)  100%
    );
  }

  /* ── Contenido: pegado al fondo de la card ── */
  .card-content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;   /* todo el texto va abajo */
    padding: 1.5rem;
  }

  /* ── Ícono ── */
  .card-icon {
    font-size: 1.6rem;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 0.6rem;
    transition: color 0.3s ease;
  }

  .solution-card:hover .card-icon {
    color: #1279C8;
  }

  /* ── Título ── */
  .card-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.3;
    margin-bottom: 0.6rem;
    transition: color 0.3s ease;
  }

  .solution-card:hover .card-title {
    color: #a8d4f5;
  }

  /* ── Descripción ── */
  .card-description {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  /* ── CTA link ── */
  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .card-link:hover {
    color: #1279C8;
  }

  .card-link-icon {
    font-size: 1rem;
    transition: transform 0.3s ease;
  }

  .card-link:hover .card-link-icon {
    transform: translateX(4px);
  }
</style>