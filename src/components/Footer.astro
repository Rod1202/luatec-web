---
import { Image } from "astro:assets";
import logoBase from "../assets/branding/logo_base.avif";
import LiquidEther from "./LiquidEther";
---
<footer class="w-full py-16 md:py-24 bg-transparent relative overflow-hidden group/footer">
    <!-- Interactive LiquidEther Background -->
    <LiquidEther
        client:only="react"
        colors={['#06b6d4', '#1e3a8a', '#3b82f6']}
        mouseForce={20}
        cursorSize={100}
        isViscous
        viscous={30}
        iterationsViscous={16}
        iterationsPoisson={16}
        resolution={0.4}
        isBounce={false}
        autoDemo
        autoSpeed={0.5}
        autoIntensity={2.2}
        takeoverDuration={0.25}
        autoResumeDelay={3000}
        autoRampDuration={0.6}
        className="absolute inset-0 w-full h-full z-0 opacity-40 mix-blend-screen transition-opacity duration-1000 [mask-image:linear-gradient(to_bottom,transparent_0%,black_20%)]"
    />
    
    <div class="max-w-4xl mx-auto px-6 relative z-10 flex flex-col items-center">

        <!-- CTA TITLE -->
        <h2 class="text-4xl md:text-5xl font-extrabold text-white text-center tracking-wide mb-12">
            ¿Listo para transformar tu<br/>
            <span class="text-blue-500">infraestructura?</span>
        </h2>

        <!-- SIMPLE CTA BUTTON -->
        <div class="w-full flex justify-center mb-24">
            <a 
                href="/formulario"
                data-astro-prefetch
                aria-label="Solicitar Información"
                class="relative inline-flex items-center justify-center px-8 py-3.5 md:px-10 md:py-4 rounded-full bg-blue-600 text-white shadow-[0_3px_5px_-1px_rgba(37,99,235,0.4),0_6px_10px_0_rgba(37,99,235,0.2),0_1px_18px_0_rgba(37,99,235,0.12)] hover:bg-blue-600/90 hover:shadow-[0_5px_5px_-3px_rgba(37,99,235,0.4),0_8px_10px_1px_rgba(37,99,235,0.2),0_3px_14px_2px_rgba(37,99,235,0.12)] transition-all duration-300 active:scale-95 overflow-hidden group"
            >
                <div class="absolute inset-0 bg-white opacity-0 group-hover:opacity-10 transition-opacity duration-300 pointer-events-none"></div>
                <div class="relative z-10 flex items-center justify-center gap-3">
                    <span class="text-base md:text-[1.1rem] font-medium tracking-wide">Solicitar Información</span>
                    <span class="material-symbols-outlined text-[20px] md:text-[24px] transition-transform duration-300 group-hover:translate-x-1">arrow_forward</span>
                </div>
            </a>
        </div>

        <!-- BRANDING -->
        <div class="flex flex-col items-center gap-6 mb-12">
            <Image 
                src={logoBase} 
                alt="LUATEC SOLUTIONS" 
                width={200}
                height={80}
                class="h-28 w-auto object-contain" 
                loading="lazy"
            />
            
            <!-- Social Icons -->
            <div class="flex gap-4">
                <!-- LinkedIn -->
                <a class="w-10 h-10 rounded-xl bg-[#0a0a0a] border border-white/5 flex items-center justify-center text-slate-400 hover:bg-blue-600 hover:text-white hover:border-blue-500 transition-all duration-300"
                   href="https://www.linkedin.com/company/luatec-solutions/?viewAsMember=true"
                   target="_blank"
                   rel="noopener noreferrer"
                   aria-label="LinkedIn"
                   data-astro-prefetch>
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"/>
                    </svg>
                </a>

                <!-- Instagram -->
                <a class="w-10 h-10 rounded-xl bg-[#0a0a0a] border border-white/5 flex items-center justify-center text-slate-400 hover:bg-blue-600 hover:text-white hover:border-blue-500 transition-all duration-300"
                   href="https://www.instagram.com"
                   target="_blank"
                   rel="noopener noreferrer"
                   aria-label="Instagram"
                   data-astro-prefetch>
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path fill-rule="evenodd" d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.069-4.85.069-3.204 0-3.584-.012-4.849-.069-3.225-.149-4.771-1.664-4.919-4.919-.058-1.265-.069-1.644-.069-4.849 0-3.204.012-3.584.069-4.849.149-3.225 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" clip-rule="evenodd"/>
                    </svg>
                </a>
            </div>
        </div>

        <!-- BOTTOM COPYRIGHT -->
        <div class="text-center pb-4">
            <p class="text-[0.55rem] md:text-[0.65rem] font-bold uppercase tracking-widest text-slate-500">
                © {new Date().getFullYear()} LUATEC SOLUTIONS • POWERED BY RODRIGO CARBONEL
            </p>
        </div>

    </div>
</footer>
