---
import { Image } from "astro:assets";
import logoBase from "../assets/branding/logo_base.avif";

export interface Props {
    showCTA?: boolean;
}

const { showCTA = true } = Astro.props;
---

<footer class="w-full pt-12 pb-16 md:pt-16 md:pb-24 relative overflow-hidden" style="background: linear-gradient(to bottom right, #053D8A, #031b40);">

    <div class="max-w-4xl mx-auto px-6 relative z-10 flex flex-col items-center">

{ showCTA && (
    <div class="footer-cta-wrapper">
        <span class="footer-eyebrow"> </span>
        <h2 class="footer-heading">
            ¿Listo para transformar tu<br/>
            <span class="footer-heading-accent">infraestructura?</span>
        </h2>
        <div class="footer-line"></div>
        <div class="w-full flex justify-center mb-24">
            <a href="/formulario" class="footer-cta group">
                <div class="footer-cta-overlay"></div>
                <div class="footer-cta-inner">
                    <span class="footer-cta-label">Solicitar Información</span>
                    <span class="material-symbols-outlined footer-cta-icon">arrow_forward</span>
                </div>
            </a>
        </div>
    </div>
)}

        <div class="flex flex-col items-center gap-6 mb-12">

            <Image
                src={logoBase}
                alt="LUATEC SOLUTIONS"
                width={220}
                height={90}
                class="h-20 md:h-24 w-auto object-contain"
                loading="lazy"
            />

<div class="flex gap-4">
    <a class="footer-social-link" href="https://www.linkedin.com/company/luatec-solutions/?viewAsMember=true" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"/>
        </svg>
    </a>

    <a class="footer-social-link" href="https://www.instagram.com/luatec_solutions/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.069-4.85.069-3.204 0-3.584-.012-4.849-.069-3.225-.149-4.771-1.664-4.919-4.919-.058-1.265-.069-1.644-.069-4.849 0-3.204.012-3.584.069-4.849.149-3.225 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" clip-rule="evenodd"/>
        </svg>
    </a>
</div>
        </div>

        <div class="footer-divider"></div>

        <div class="text-center pb-4">
            <p class="footer-copyright">
                © {new Date().getFullYear()} LUATEC SOLUTIONS • POWERED BY ARCI
            </p>
        </div>

    </div>
</footer>

<style>
    /* Eyebrow */
    .footer-eyebrow {
        display: block;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.25em;
        color: #7CC5FF;
        margin-bottom: 0.75rem;
        text-align: center;
    }

    /* Heading */
    .footer-heading {
        font-size: clamp(1.875rem, 4vw, 3rem);
        font-weight: 800;
        color: #ffffff;
        letter-spacing: 0.02em;
        text-align: center;
        line-height: 1.15;
        margin-bottom: 1rem;
    }

    .footer-heading-accent {
        color: #7CC5FF;
    }

    /* Línea decorativa */
    .footer-line {
        width: 3rem;
        height: 4px;
        background: #7CC5FF;
        border-radius: 9999px;
        margin: 0 auto 3rem;
    }

    /* Botón CTA */
    .footer-cta {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.875rem 2rem;
        border-radius: 9999px;
        background-color: #ffffff;
        color: #053D8A;
        text-decoration: none;
        font-weight: 600;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(255, 255, 255, 0.15);
        transition: background-color 0.3s ease,
                    color 0.3s ease,
                    transform 0.3s ease,
                    box-shadow 0.3s ease;
    }

    .footer-cta:hover {
        background-color: #1279C8;
        color: #ffffff;
        transform: translateY(-3px);
        box-shadow: 0 15px 35px rgba(18, 121, 200, 0.4);
    }

    .footer-cta:active {
        transform: scale(0.97);
    }

    .footer-cta-label {
        font-size: 1rem;
        font-weight: 500;
        letter-spacing: 0.02em;
    }

    .footer-cta-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
}

.footer-cta-overlay {
    position: absolute;
    inset: 0;
    background: white;
    opacity: 0;
    pointer-events: none;
    border-radius: 9999px;
    transition: opacity 0.3s ease;
}

.footer-cta:hover .footer-cta-overlay {
    opacity: 0.1;
}

.footer-cta-inner {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
}

    @media (min-width: 768px) {
        .footer-cta {
            padding: 1rem 2.5rem;
        }
        .footer-cta-label {
            font-size: 1.1rem;
        }
    }

    .footer-cta-icon {
        font-size: 20px;
        transition: transform 0.3s ease;
    }

    .footer-cta:hover .footer-cta-icon {
        transform: translateX(4px);
    }

    /* Iconos sociales */
    .footer-social-link {
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 0.75rem;
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255, 255, 255, 0.7);
        text-decoration: none;
        transition: color 0.3s ease, transform 0.3s ease;
    }

    .footer-social-link:hover {
        color: #7CC5FF;
        transform: translateY(-4px);
    }

    /* Divisor */
    .footer-divider {
        width: 100%;
        height: 1px;
        background: rgba(255, 255, 255, 0.15);
        margin-bottom: 2rem;
    }

    /* Copyright */
    .footer-copyright {
        font-size: 0.6rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.25em;
        color: rgba(255, 255, 255, 0.5);
    }

    @media (min-width: 768px) {
        .footer-copyright {
            font-size: 0.65rem;
        }
    }
</style>