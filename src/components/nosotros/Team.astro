---
---

<section class="section-standard" id="equipo-seccion">
    <div class="container-main">
        <div class="grid lg:grid-cols-2 gap-16 items-center w-full">
            <div class="team-content opacity-0 translate-y-10 transition-all duration-1000 ease-out">
                <span class="eyebrow">
                    Nuestro Equipo
                </span>

                <h2 class="section-heading">
                    Expertos dedicados a<br />su tranquilidad
                </h2>
                <p class="team-description">
                    Contamos con un equipo multidisciplinario de ingenieros y consultores certificados por los principales fabricantes de tecnología a nivel mundial. Nuestra pasión es resolver problemas complejos con soluciones simples, robustas y escalables.
                </p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 team-metrics">
                <div class="metric-card stat-item group relative py-10 px-8 rounded-[2.5rem] text-center transition-all duration-300 hover:bg-slate-50 opacity-0 translate-y-10 flex flex-col justify-center items-center">
                    <div class="relative z-10 transition-transform duration-300">
                        <div class="text-5xl font-extrabold text-slate-900 mb-3 tracking-tighter transition-colors duration-300 group-hover:text-[#274495]">
                            +50
                        </div>
                        <p class="text-[0.65rem] md:text-[0.75rem] font-bold text-slate-500 uppercase tracking-[0.2em] opacity-70 group-hover:opacity-100 transition-opacity">
                            Certificaciones
                        </p>
                    </div>
                </div>

                <!-- Card 2 -->
                <div class="metric-card stat-item group relative py-10 px-8 rounded-[2.5rem] text-center transition-all duration-300 hover:bg-slate-50 opacity-0 translate-y-10 flex flex-col justify-center items-center">
                    <div class="relative z-10 transition-transform duration-300">
                        <div class="text-5xl font-extrabold text-slate-900 mb-3 tracking-tighter transition-colors duration-300 group-hover:text-[#274495]">
                            +50
                        </div>
                        <p class="text-[0.65rem] md:text-[0.75rem] font-bold text-slate-500 uppercase tracking-[0.2em] opacity-70 group-hover:opacity-100 transition-opacity">
                            Implementaciones
                        </p>
                    </div>
                </div>

                <div class="metric-card stat-item group relative py-10 px-8 rounded-[2.5rem] text-center transition-all duration-300 hover:bg-slate-50 opacity-0 translate-y-10 flex flex-col justify-center items-center">
                    <div class="relative z-10 transition-transform duration-300">
                        <div class="text-5xl font-extrabold text-slate-900 mb-3 tracking-tighter transition-colors duration-300 group-hover:text-[#274495]">
                            24/7
                        </div>
                        <p class="text-[0.65rem] md:text-[0.75rem] font-bold text-slate-500 uppercase tracking-[0.2em] opacity-70 group-hover:opacity-100 transition-opacity">
                            Disponibilidad
                        </p>
                    </div>
                </div>

                <!-- Card 4 -->
                <div class="metric-card stat-item group relative py-10 px-8 rounded-[2.5rem] text-center transition-all duration-300 hover:bg-slate-50 opacity-0 translate-y-10 flex flex-col justify-center items-center">
                    <div class="relative z-10 transition-transform duration-300">
                        <div class="text-5xl font-extrabold text-slate-900 mb-3 tracking-tighter transition-colors duration-300 group-hover:text-[#274495]">
                            100%
                        </div>
                        <p class="text-[0.65rem] md:text-[0.75rem] font-bold text-slate-500 uppercase tracking-[0.2em] opacity-70 group-hover:opacity-100 transition-opacity">
                            Satisfacción
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    const observerOptions = {
        threshold: 0.1
    };

    const teamObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                // Animate entrance for content and cards
                const content = entry.target.querySelector('.team-content');
                const cards = entry.target.querySelectorAll('.metric-card');
                
                if (content) {
                    content.classList.remove('opacity-0', 'translate-y-10');
                    content.classList.add('opacity-100', 'translate-y-0');
                }
                
                cards.forEach(card => {
                    card.classList.remove('opacity-0', 'translate-y-10');
                    card.classList.add('opacity-100', 'translate-y-0');
                });
                
                teamObserver.unobserve(entry.target);
            }
        });
    }, observerOptions);

    const section = document.getElementById('equipo-seccion');
    if (section) teamObserver.observe(section);
</script>

<style>
    .metric-card {
        box-shadow: 
            0 20px 50px rgba(0,0,0,0.05), 
            inset 0 1px 1px rgba(255,255,255,0.8);
    }
    .team-content p {
    text-wrap: balance;
    orphans: 3;
    widows: 3;
    }

    .metric-card::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, rgba(59, 130, 246, 0.08) 0%, transparent 70%);
        opacity: 0;
        transition: opacity 0.4s ease;
        pointer-events: none;
    }
    
    .metric-card:hover::after {
        opacity: 1;
    }


    /* -------------------------
   Header (igual a Solutions)
------------------------- */

.eyebrow {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: #1279C8;
    margin-bottom: 0.75rem;
}

.section-heading {
    font-size: clamp(1.875rem, 4vw, 3rem);
    font-weight: 800;
    color: #053D8A;
    letter-spacing: 0.02em;
    margin-bottom: 1rem;
}

.heading-line {
    width: 3rem;
    height: 4px;
    background: #1279C8;
    border-radius: 9999px;
}

/* -------------------------
   Texto descriptivo
------------------------- */

.team-description {
    font-size: 1rem;
    line-height: 1.9;
    color: #64748b;
    max-width: 34rem;
}

/* -------------------------
   Cards
------------------------- */

.metric-card {
    background: #ffffff;

    border: 1px solid rgba(18,121,200,0.08);

    box-shadow:
        0 4px 20px rgba(5,61,138,0.08),
        0 20px 40px rgba(5,61,138,0.05);

    transition:
        transform .4s ease,
        box-shadow .4s ease,
        border-color .4s ease;
}

.metric-card:hover {
    transform: translateY(-6px);

    border-color: rgba(18,121,200,0.2);

    box-shadow:
        0 10px 30px rgba(5,61,138,0.15),
        0 25px 60px rgba(5,61,138,0.10);
}
</style>
