---
import GradientText from '../GradientText';
---

<section
  class="hero relative w-full flex flex-col justify-center pb-24 md:pb-32 overflow-hidden"
  style="padding-top: calc(var(--header-height) + 6rem);"
  id="inicio">
    <!-- Hero Content -->
    <div class="hero-content w-full max-w-7xl mx-auto px-6 relative z-10">
        <div class="max-w-4xl">
            <span class="inline-block px-4 py-1.5 rounded-full bg-[#053D8A]/30 text-white text-[10px] mobile:text-xs font-bold tracking-widest uppercase mb-8 border border-white/20 backdrop-blur-sm">
                SOLUCIONES TECNOLÓGICAS CORPORATIVAS
            </span>
            <h1 class="text-5xl md:text-7xl font-extrabold leading-[1.1] mb-8 text-white">
                La infraestructura <br/>
                que convierte tu 
                <GradientText 
                  client:load 
                  colors={["#06b6d4", "#3b82f6", "#60a5fa", "#06b6d4"]} 
                  animationSpeed={8} 
                  showBorder={false} 
                  className="font-extrabold"
                >
                  visión
                </GradientText> 
                en resultados
            </h1>
            <p class="text-lg md:text-xl text-slate-100 mb-12 max-w-2xl leading-relaxed">
                Diseñamos ecosistemas digitales de alto rendimiento para que tu tecnología sea tu mayor ventaja competitiva.
            </p>
            
            <!-- Registration Form -->
            <div class="w-full max-w-xl">
                 <form action="/formulario" method="GET" class="relative group">
                    <div class="relative flex flex-col md:flex-row items-center bg-transparent md:bg-white/5 md:backdrop-blur-md md:border md:border-white/10 rounded-2xl md:p-1.5 md:shadow-[0_20px_50px_rgba(0,0,0,0.5)] transition-all duration-300 md:group-hover:border-white/20 gap-4 md:gap-0">
                        <!-- Input container: Styled on mobile -->
                        <div class="relative flex-grow w-full md:w-auto flex items-center pl-4 group/input bg-white/5 backdrop-blur-md border border-white/10 rounded-xl md:rounded-none md:bg-transparent md:backdrop-blur-none md:border-none shadow-2xl md:shadow-none">
                            <span class="material-symbols-outlined text-blue-400/70 mr-3 transition-colors group-focus-within/input:text-blue-400">mail</span>
                            <input 
                                type="email" 
                                name="email"
                                placeholder="Tu correo electrónico" 
                                class="w-full bg-transparent border-none text-white placeholder:text-slate-400 focus:ring-0 py-4 md:py-3 text-sm md:text-base outline-none font-medium"
                                required
                            />
                        </div>
                        <!-- Button: Styled with consistent rounding on mobile -->
                        <button type="submit" class="w-full md:w-auto bg-blue-600 hover:bg-blue-500 text-white font-bold py-4 md:py-3 px-8 rounded-xl transition-all flex items-center justify-center gap-2 whitespace-nowrap shadow-xl active:scale-95 border border-white/10 md:border-none">
                            Solicitar Información
                            <span class="material-symbols-outlined text-sm">arrow_forward</span>
                        </button>
                        <a href="/formulario" data-astro-prefetch class="hidden" aria-hidden="true">Prefetch</a>
                    </div>
                </form>
                <p class="mt-4 text-xs text-slate-500 ml-2 font-medium">
                    Recibe una asesoría técnica personalizada en menos de 24 horas.
                </p>
            </div>
        </div>
    </div>

    <!-- Gradients removed as requested -->

    <script>
        window.addEventListener('scroll', () => {
            const hero = document.getElementById('inicio');
            if (hero) {
                const scrollPosition = window.scrollY;
                hero.style.backgroundPositionY = `${scrollPosition * 0.5}px`;
                // Optional: opacity fade for parallax content if desired
                // hero.style.opacity = `${1 - scrollPosition / 1000}`;
            }
        });
    </script>
</section>
