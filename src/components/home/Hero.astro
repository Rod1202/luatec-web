---
import GradientText from '../GradientText';
---

<section
  class="hero relative w-full min-h-[100dvh] flex flex-col justify-center overflow-hidden pt-[110px] pb-12"
  id="inicio">
    <!-- Hero Content -->
    <div class="hero-content w-full max-w-7xl mx-auto px-6 relative z-10">
        <div class="max-w-3xl mt-4 md:mt-8">
            <h1 class="text-5xl md:text-7xl font-extrabold leading-[1.1] mb-8 text-white">
                Infraestructura <br/>
                que convierte tu 
                <GradientText 
                  client:load 
                  colors={["#06b6d4", "#3b82f6", "#60a5fa", "#06b6d4"]} 
                  animationSpeed={8} 
                  showBorder={false} 
                  className="font-extrabold"
                >
                  visión
                </GradientText> 
                en resultados
            </h1>
            <p class="text-lg md:text-xl text-slate-100 mb-12 max-w-2xl leading-relaxed">
                Diseñamos ecosistemas digitales de alto rendimiento para que tu tecnología sea tu mayor ventaja competitiva.
            </p>
            
            <div class="flex flex-col items-start gap-4">
                <a 
                    href="/formulario"        
                    class="relative inline-flex items-center justify-center px-8 py-3.5 md:px-10 md:py-4 rounded-full bg-blue-600 text-white shadow-[0_3px_5px_-1px_rgba(37,99,235,0.4),0_6px_10px_0_rgba(37,99,235,0.2),0_1px_18px_0_rgba(37,99,235,0.12)] hover:bg-blue-600/90 hover:shadow-[0_5px_5px_-3px_rgba(37,99,235,0.4),0_8px_10px_1px_rgba(37,99,235,0.2),0_3px_14_2px_rgba(37,99,235,0.12)] transition-all duration-300 active:scale-95 overflow-hidden group"
                >
                    <div class="absolute inset-0 bg-white opacity-0 group-hover:opacity-10 transition-opacity duration-300 pointer-events-none"></div>
                    <div class="relative z-10 flex items-center justify-center gap-3">
                        <span class="text-base md:text-[1.1rem] font-medium tracking-wide">Conoce más</span>
                        <span class="material-symbols-outlined text-[20px] md:text-[24px] transition-transform duration-300 group-hover:translate-x-1">arrow_forward</span>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <!-- Gradients removed as requested -->

    <script>
        // Parallax effect
        window.addEventListener('scroll', () => {
            const hero = document.getElementById('inicio');
            if (hero) {
                const scrollPosition = window.scrollY;
                hero.style.backgroundPositionY = `${scrollPosition * 0.5}px`;
            }
        });

        // "Conoce más" clean scroll without updating URL hash
        const ctaButton = document.getElementById('cta-scroll');
        const targetSection = document.getElementById('impacto-numeros');

        ctaButton?.addEventListener('click', (e) => {
            e.preventDefault();
            targetSection?.scrollIntoView({ behavior: 'smooth' });
        });
    </script>
</section>
