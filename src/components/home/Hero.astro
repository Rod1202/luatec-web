---
import GradientText from '../GradientText';
---

<section
  class="hero relative w-full min-h-[100dvh] flex flex-col justify-center overflow-hidden pt-[110px] pb-12"
  id="inicio">
    <!-- Hero Content -->
    <div class="hero-content w-full max-w-7xl mx-auto px-6 relative z-10">
        <div class="max-w-3xl mt-4 md:mt-8">
            <h1 class="text-5xl md:text-7xl font-extrabold leading-[1.1] mb-8 text-white">
                Infraestructura <br/>
                que convierte tu 
                <GradientText 
                  client:load 
                  colors={["#06b6d4", "#3b82f6", "#60a5fa", "#06b6d4"]} 
                  animationSpeed={8} 
                  showBorder={false} 
                  className="font-extrabold"
                >
                  visión
                </GradientText> 
                en resultados
            </h1>
            <p class="text-lg md:text-xl text-slate-100 mb-12 max-w-2xl leading-relaxed">
                Diseñamos ecosistemas digitales de alto rendimiento para que tu tecnología sea tu mayor ventaja competitiva.
            </p>
            
            <div class="w-full max-w-xl">
                <form action="/formulario" class="relative flex items-center w-full max-w-[22rem] md:max-w-md bg-white/10 backdrop-blur-md border border-white/20 rounded-full p-1.5 shadow-lg group focus-within:border-blue-400 focus-within:bg-white/15 transition-all duration-300 mb-4">
                    <input 
                        type="email" 
                        placeholder="Correo electrónico" 
                        class="w-full bg-transparent border-none outline-none text-white placeholder-slate-300 px-5 py-2.5 text-base focus:ring-0" 
                        required
                    />
                    <button type="submit" class="flex-shrink-0 w-10 h-10 md:w-11 md:h-11 bg-blue-600 hover:bg-blue-500 rounded-full flex items-center justify-center text-white transition-all shadow-md active:scale-95">
                        <span class="material-symbols-outlined text-[1.2rem]">arrow_forward</span>
                    </button>
                </form>
                <p class="mt-4 text-xs text-slate-400 font-medium ml-2">
                    Recibe una asesoría técnica personalizada en menos de 24 horas.
                </p>
            </div>
        </div>
    </div>

    <!-- Gradients removed as requested -->

    <script>
        window.addEventListener('scroll', () => {
            const hero = document.getElementById('inicio');
            if (hero) {
                const scrollPosition = window.scrollY;
                hero.style.backgroundPositionY = `${scrollPosition * 0.5}px`;
                // Optional: opacity fade for parallax content if desired
                // hero.style.opacity = `${1 - scrollPosition / 1000}`;
            }
        });
    </script>
</section>
