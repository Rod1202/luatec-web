---
import { Image } from "astro:assets";
import deltronLogo from "../../assets/logos/deltron.avif";
import ingramLogo from "../../assets/logos/ingram.avif";
import intcomexLogo from "../../assets/logos/intcomex.avif";
import maximLogo from "../../assets/logos/maxim.avif";

---
<section class="bg-transparent overflow-hidden w-full relative pt-16 pb-32 md:pt-24 md:pb-48" id="carousel-section">
    <div class="max-w-7xl mx-auto px-6 mb-12 md:mb-16">
        <h2 class="text-4xl md:text-5xl font-extrabold text-center text-white tracking-wide">
            Alianzas Estratégicas
        </h2>
    </div>
    
    <div class="max-w-7xl mx-auto px-6 relative">
        <!-- Fade Mask Container -->
        <div class="logos-mask overflow-hidden relative">
            <div class="flex w-max animate-scroll gap-32 items-center py-4">
                <!-- Set 1 -->
                <div class="flex items-center gap-24 shrink-0 grayscale hover:grayscale-0 transition-all duration-500">
                    <Image src={maximLogo} alt="Maxim" height={160} quality="high" class="h-16 md:h-20 w-auto object-contain brightness-0 invert opacity-70 hover:opacity-100" style="max-width: 170px; transform: scale(1.955);" loading="lazy" />
                    <Image src={deltronLogo} alt="Deltron" height={160} quality="high" class="h-16 md:h-20 w-auto object-contain brightness-0 invert opacity-70 hover:opacity-100" style="max-width: 260px; transform: scale(1.0695);" loading="lazy" />
                    <Image src={ingramLogo} alt="Ingram" height={160} quality="high" class="h-16 md:h-20 w-auto object-contain brightness-0 invert opacity-70 hover:opacity-100" style="max-width: 200px; transform: scale(1.357);" loading="lazy" />
                    <Image src={intcomexLogo} alt="Intcomex" height={160} quality="high" class="h-16 md:h-20 w-auto object-contain brightness-0 invert opacity-70 hover:opacity-100" style="max-width: 310px; transform: scale(0.828);" loading="lazy" />
                </div>
                
                <!-- Set 2 -->
                <div class="flex items-center gap-24 shrink-0 grayscale hover:grayscale-0 transition-all duration-500">
                    <Image src={maximLogo} alt="Maxim" height={160} quality="high" class="h-16 md:h-20 w-auto object-contain brightness-0 invert opacity-70 hover:opacity-100" style="max-width: 170px; transform: scale(1.955);" loading="lazy" />
                    <Image src={deltronLogo} alt="Deltron" height={160} quality="high" class="h-16 md:h-20 w-auto object-contain brightness-0 invert opacity-70 hover:opacity-100" style="max-width: 260px; transform: scale(1.0695);" loading="lazy" />
                    <Image src={ingramLogo} alt="Ingram" height={160} quality="high" class="h-16 md:h-20 w-auto object-contain brightness-0 invert opacity-70 hover:opacity-100" style="max-width: 200px; transform: scale(1.357);" loading="lazy" />
                    <Image src={intcomexLogo} alt="Intcomex" height={160} quality="high" class="h-16 md:h-20 w-auto object-contain brightness-0 invert opacity-70 hover:opacity-100" style="max-width: 310px; transform: scale(0.828);" loading="lazy" />
                </div>

                <!-- Set 3 -->
                <div class="flex items-center gap-24 shrink-0 grayscale hover:grayscale-0 transition-all duration-500">
                    <Image src={maximLogo} alt="Maxim" height={160} quality="high" class="h-16 md:h-20 w-auto object-contain brightness-0 invert opacity-70 hover:opacity-100" style="max-width: 170px; transform: scale(1.955);" loading="lazy" />
                    <Image src={deltronLogo} alt="Deltron" height={160} quality="high" class="h-16 md:h-20 w-auto object-contain brightness-0 invert opacity-70 hover:opacity-100" style="max-width: 260px; transform: scale(1.0695);" loading="lazy" />
                    <Image src={ingramLogo} alt="Ingram" height={160} quality="high" class="h-16 md:h-20 w-auto object-contain brightness-0 invert opacity-70 hover:opacity-100" style="max-width: 200px; transform: scale(1.357);" loading="lazy" />
                    <Image src={intcomexLogo} alt="Intcomex" height={160} quality="high" class="h-16 md:h-20 w-auto object-contain brightness-0 invert opacity-70 hover:opacity-100" style="max-width: 310px; transform: scale(0.828);" loading="lazy" />
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .logos-mask {
        mask-image: linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
        -webkit-mask-image: linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
    }

    .animate-scroll {
        animation: scroll 30s linear infinite;
    }
    
    @keyframes scroll {
        0% { transform: translateX(0); }
        100% { transform: translateX(-33.33%); } /* Adjusted for 3 sets */
    }
</style>
