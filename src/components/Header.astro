---
import { Image } from "astro:assets";
import logoBase from "../assets/branding/logo_base.avif";
const pathname = new URL(Astro.request.url).pathname;
const isFormPage = pathname === '/formulario' || pathname === '/formulario/';

// Use smaller height and padding exactly like the original design for the form page
const headerHeight = isFormPage ? 'h-[140px] md:h-[160px]' : 'h-[140px] md:h-[160px]';
const headerPadding = isFormPage ? 'pt-10 pb-4 md:pt-12 md:pb-5' : 'pt-10 pb-4 md:pt-12 md:pb-5';
---

<nav id="main-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-300">
  <div id="header-bg" class={`absolute top-0 left-0 w-full ${headerHeight} transition-all duration-300 pointer-events-none -z-10 bg-transparent`}></div>
  <div class={`relative z-10 max-w-7xl mx-auto px-6 flex items-center justify-between ${headerPadding}`}>
    <div class="flex items-center gap-2">
      <a href="/" aria-label="Volver al inicio" class="cursor-pointer transition-transform hover:scale-105">
<Image 
  src={logoBase} 
  alt="LUATEC" 
  width={208}
  height={84}
  id="header-logo"
  class="h-[68px] md:h-[84px] w-auto scale-100 origin-left translate-y-[1px] translate-x-[-8px] transition-all duration-300"
  loading="eager"
/>
      </a>
    </div>
    
    { !isFormPage && (
      <div class="flex items-center gap-4">
          <a
  id="header-mail"
  class="relative flex items-center justify-center w-11 h-11 md:w-12 md:h-12 rounded-full border border-white/30 bg-white/10 text-white backdrop-blur-sm transition-all duration-300 active:scale-95 group"
            href="/formulario"
            data-astro-prefetch
            aria-label="Mensaje"
          >
            <span class="relative z-10 material-symbols-outlined text-[20px] md:text-[24px] transition-transform duration-300 group-hover:scale-110">mail</span>
          </a>
      </div>
    )}
  </div>
</nav>

<script>
  const headerBg = document.getElementById("header-bg");
  const logo = document.getElementById("header-logo");
  const mail = document.getElementById("header-mail");

  function updateHeader() {

    if (window.scrollY > 50) {

      // HEADER BLANCO

      headerBg?.classList.add(
        "bg-white",
        "backdrop-blur-xl",
        "border-b",
        "border-slate-200"
      );

      // LOGO AZUL

      logo?.classList.add("logo-blue");

      // ICONO AZUL

      mail?.classList.remove(
        "border-white/30",
        "bg-white/10",
        "text-white"
      );

      mail?.classList.add(
        "border-slate-200",
        "bg-white",
        "text-[#053D8A]",
        "shadow-sm"
      );

    } else {

      // HEADER TRANSPARENTE

      headerBg?.classList.remove(
        "bg-white",
        "backdrop-blur-xl",
        "border-b",
        "border-slate-200"
      );

      // LOGO BLANCO

      logo?.classList.remove("logo-blue");

      // ICONO BLANCO

      mail?.classList.remove(
        "border-slate-200",
        "bg-white",
        "text-[#053D8A]",
        "shadow-sm"
      );

      mail?.classList.add(
        "border-white/30",
        "bg-white/10",
        "text-white"
      );
    }
  }

  updateHeader();

  window.addEventListener("scroll", updateHeader);
</script>

<style>
.logo-blue {
  filter:
    brightness(0)
    saturate(100%)
    invert(16%)
    sepia(98%)
    saturate(2248%)
    hue-rotate(208deg)
    brightness(94%)
    contrast(98%);
}
</style>