---
import { Image } from "astro:assets";
import logoBase from "../assets/branding/logo_base.avif";
const pathname = new URL(Astro.request.url).pathname;
const isFormPage = pathname === '/formulario' || pathname === '/formulario/';

const headerPadding = isFormPage ? 'pt-3 pb-3 md:pt-4 md:pb-4' : 'pt-3 pb-3 md:pt-4 md:pb-4';

const navLinks = [
  { label: 'Inicio',    href: '#inicio' },
  { label: 'Nosotros',  href: '#equipo-seccion' },
  { label: 'Servicios', href: '#soluciones' },

];
---

<nav id="main-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-300">
  <div id="header-bg" class="absolute top-0 left-0 w-full h-full transition-all duration-300 pointer-events-none -z-10 bg-transparent"></div>

  <div class={`relative z-10 max-w-5xl mx-auto px-6 flex items-center justify-between ${headerPadding}`}>
    
    <!-- LOGO -->
    <div class="flex items-center gap-2">
      <a href="/" aria-label="Volver al inicio" class="cursor-pointer transition-transform hover:scale-105">
        <Image
          src={logoBase}
          alt="LUATEC"
          width={208}
          height={84}
          id="header-logo"
          class="h-[68px] md:h-[84px] w-auto scale-100 origin-left translate-y-[1px] translate-x-[-8px] transition-all duration-300"
          loading="eager"
        />
      </a>
    </div>

 <!-- NAV LINKS (solo si no es página formulario) -->
    {!isFormPage && (
      <Fragment>
        <!-- Desktop -->
        <div class="hidden md:flex items-center gap-6">
          {navLinks.map(link => (
            
             <a href={link.href}
              class="nav-link text-sm font-medium text-white/90 hover:text-white transition-colors duration-200 relative after:absolute after:bottom-[-3px] after:left-0 after:w-0 after:h-[2px] after:bg-white after:transition-all after:duration-300 hover:after:w-full"
            >
              {link.label}
            </a>
          ))}

          <!-- CTA -->
          
            <a href="/formulario"
            data-astro-prefetch
            id="cta-btn"
            class="ml-2 px-5 py-2.5 rounded-lg bg-[#1279C8] text-white text-sm font-semibold uppercase tracking-wide transition-all duration-300 hover:bg-[#053D8A] hover:shadow-lg active:scale-95"
          >
            Solicitar Cotización
          </a>
        </div>

        <!-- Mobile: solo el CTA + hamburger -->
        <div class="flex md:hidden items-center gap-3">
          
           <a href="/formulario"
            data-astro-prefetch
            class="px-4 py-2 rounded-lg bg-[#1279C8] text-white text-xs font-semibold uppercase tracking-wide transition-all duration-300 hover:bg-[#053D8A] active:scale-95"
          >
            Cotización
          </a>
          <button id="mobile-menu-btn" class="text-white p-1" aria-label="Menú">
            <span class="material-symbols-outlined text-[28px]">menu</span>
          </button>
        </div>
      </Fragment>
    )}
  </div>

  <!-- Mobile Menu Dropdown -->
  {!isFormPage && (
    <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-[#031b40]/95 backdrop-blur-md border-t border-white/10 py-4 px-6 flex flex-col gap-4">
      {navLinks.map(link => (
        
          <a href={link.href}
          class="mobile-nav-link text-white/90 text-base font-medium py-1 hover:text-white transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  )}
</nav>

<script>
  // ─── Scroll Header ───────────────────────────────────────────
  const headerBg  = document.getElementById("header-bg");
  const logo      = document.getElementById("header-logo");
  const ctaBtn    = document.getElementById("cta-btn");
  const navLinks  = document.querySelectorAll(".nav-link");

  function updateHeader() {
    const scrolled = window.scrollY > 50;

    // Fondo
    headerBg?.classList.toggle("bg-white",          scrolled);
    headerBg?.classList.toggle("backdrop-blur-xl",  scrolled);
    headerBg?.classList.toggle("border-b",          scrolled);
    headerBg?.classList.toggle("border-slate-200",  scrolled);

    // Logo
    logo?.classList.toggle("logo-blue", scrolled);

    // Links de nav
    navLinks.forEach(link => {
      link.classList.toggle("text-[#053D8A]", scrolled);
      link.classList.toggle("text-white/90",  !scrolled);
      link.classList.toggle("after:bg-[#053D8A]", scrolled);
      link.classList.toggle("after:bg-white",     !scrolled);
    });

    // CTA
    if (scrolled) {
      ctaBtn?.classList.replace("bg-[#1279C8]", "bg-[#053D8A]");
      ctaBtn?.classList.add("shadow-md");
    } else {
      ctaBtn?.classList.replace("bg-[#053D8A]", "bg-[#1279C8]");
      ctaBtn?.classList.remove("shadow-md");
    }
  }

  updateHeader();
  window.addEventListener("scroll", updateHeader);

  // ─── Scroll suave ────────────────────────────────────────────
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener("click", (e) => {
      const href = anchor.getAttribute("href");
      if (!href || href === "#") return;
      const target = document.querySelector(href);
      if (!target) return;
      e.preventDefault();
      const headerOffset = 100;
      const top = target.getBoundingClientRect().top + window.scrollY - headerOffset;
      window.scrollTo({ top, behavior: "smooth" });
      // Cerrar menú mobile si está abierto
      mobileMenu?.classList.add("hidden");
    });
  });

  // ─── Mobile Menu ─────────────────────────────────────────────
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu    = document.getElementById("mobile-menu");

  mobileMenuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  // Cerrar al hacer click en link mobile
  document.querySelectorAll(".mobile-nav-link").forEach(link => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden");
    });
  });
</script>

<style>
.logo-blue {
  filter:
    brightness(0)
    saturate(100%)
    invert(16%)
    sepia(98%)
    saturate(2248%)
    hue-rotate(208deg)
    brightness(94%)
    contrast(98%);
}
</style>