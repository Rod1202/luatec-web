---
import { Image } from "astro:assets";
import logoBase from "../assets/branding/logo_base.avif";
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1); // remove the first "/"
---

<nav id="main-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-300">
  <div id="header-bg" class="absolute top-0 left-0 w-full h-[90px] transition-all duration-300 pointer-events-none -z-10 bg-transparent" style="-webkit-mask-image: linear-gradient(to bottom, black 65%, transparent 100%); mask-image: linear-gradient(to bottom, black 65%, transparent 100%);"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <a href="/" aria-label="Volver al inicio" class="cursor-pointer transition-transform hover:scale-105">
        <Image 
          src={logoBase} 
          alt="LUATEC" 
          width={208}
          height={84}
          class="h-[68px] md:h-[84px] w-auto scale-100 origin-left translate-y-[1px] translate-x-[-8px] transition-transform duration-300" 
          loading="eager"
        />
      </a>
    </div>
    
    <div class="flex items-center gap-4">
        <a 
          class="flex items-center justify-center p-1.5 md:p-2 rounded-full bg-white text-slate-900 shadow-sm transition-all duration-300 hover:shadow-md active:scale-95 group" 
          href="/formulario"
          data-astro-prefetch
          aria-label="Contáctanos"
        >
          <div class="flex items-center justify-center w-8 h-8 md:w-10 md:h-10 rounded-full bg-blue-600 text-white transition-transform duration-300 group-hover:bg-blue-700">
            <span class="material-symbols-outlined text-[18px] md:text-[20px] transition-transform duration-300 group-hover:scale-110">mail</span>
          </div>
        </a>
    </div>
  </div>
</nav>

<script>
  const header = document.getElementById('main-header');
  const headerBg = document.getElementById('header-bg');
  // Target the logo image specifically for the shrink effect
  const logo = header?.querySelector('div a img'); 

  window.addEventListener('scroll', () => {
    const currentScrollY = window.scrollY;

    if (currentScrollY > 50) {
      // SCROLLED STATE
      headerBg?.classList.add('bg-gradient-to-b', 'from-[#020817]', 'via-[#0a1829]/90', 'to-transparent', 'backdrop-blur-xl', 'border-b', 'border-white/5');
      logo?.classList.remove('translate-y-[1px]');
      
    } else {
      // TOP STATE
      headerBg?.classList.remove('bg-gradient-to-b', 'from-[#020817]', 'via-[#0a1829]/90', 'to-transparent', 'backdrop-blur-xl', 'border-b', 'border-white/5');
      logo?.classList.add('translate-y-[1px]');
    }
    
    // NOTE: Padding (py-2) remains fixed. No layout shifts.
  });
</script>

