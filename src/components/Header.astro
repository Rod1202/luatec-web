---
import { Image } from "astro:assets";
import logoBase from "../assets/branding/logo_base.avif";
const pathname = new URL(Astro.request.url).pathname;
const isFormPage = pathname === '/formulario' || pathname === '/formulario/';

// Use smaller height and padding exactly like the original design for the form page
const headerHeight = isFormPage ? 'h-[90px]' : 'h-[140px] md:h-[160px]';
const headerPadding = isFormPage ? 'py-3' : 'pt-10 pb-4 md:pt-12 md:pb-5';
---

<nav id="main-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-300">
  <div id="header-bg" class={`absolute top-0 left-0 w-full ${headerHeight} transition-all duration-300 pointer-events-none -z-10 bg-transparent`} style="-webkit-mask-image: linear-gradient(to bottom, black 70%, transparent 100%); mask-image: linear-gradient(to bottom, black 70%, transparent 100%);"></div>
  <div class={`relative z-10 max-w-7xl mx-auto px-6 flex items-center justify-between ${headerPadding}`}>
    <div class="flex items-center gap-2">
      <a href="/" aria-label="Volver al inicio" class="cursor-pointer transition-transform hover:scale-105">
        <Image 
          src={logoBase} 
          alt="LUATEC" 
          width={208}
          height={84}
          class="h-[68px] md:h-[84px] w-auto scale-100 origin-left translate-y-[1px] translate-x-[-8px] transition-transform duration-300" 
          loading="eager"
        />
      </a>
    </div>
    
    { !isFormPage && (
      <div class="flex items-center gap-4">
          <a 
            class="relative flex items-center justify-center w-11 h-11 md:w-12 md:h-12 rounded-full border border-white/30 bg-white/10 backdrop-blur-md text-white shadow-sm hover:bg-white/20 hover:border-white/50 transition-all duration-300 active:scale-95 group" 
            href="/formulario"
            data-astro-prefetch
            aria-label="Mensaje"
          >
            <span class="relative z-10 material-symbols-outlined text-[20px] md:text-[24px] transition-transform duration-300 group-hover:scale-110">mail</span>
          </a>
      </div>
    )}
  </div>
</nav>

<script>
  const header = document.getElementById('main-header');
  const headerBg = document.getElementById('header-bg');
  const logo = header?.querySelector('div a img'); 

  window.addEventListener('scroll', () => {
    const currentScrollY = window.scrollY;

    if (currentScrollY > 50) {
      // SCROLLED STATE
      headerBg?.classList.add('bg-gradient-to-b', 'from-[#020817]', 'via-[#0a1829]/90', 'to-transparent', 'backdrop-blur-xl', 'border-b', 'border-white/5');
      logo?.classList.remove('translate-y-[1px]');
    } else {
      // TOP STATE
      headerBg?.classList.remove('bg-gradient-to-b', 'from-[#020817]', 'via-[#0a1829]/90', 'to-transparent', 'backdrop-blur-xl', 'border-b', 'border-white/5');
      logo?.classList.add('translate-y-[1px]');
    }
  });
</script>

